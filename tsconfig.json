{
  "compilerOptions": {
    "target": "es2023",
    "noEmit": true,
    "module": "esnext",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "strict" : true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler"
  }
}